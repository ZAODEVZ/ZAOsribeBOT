# ZAOscribe environment - copy to .env and fill values.
#
# IMPORTANT: chmod 600 .env after filling. Never commit .env.

# ----- Discord (required for voice recording) -----
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=

# Comma-separated user IDs allowed to run /scribe.
#
# FAIL-CLOSED DEFAULT: an empty list means NO ONE can record. You must
# explicitly list the Discord user IDs of admins who may start recordings.
# This is a privacy decision - an unconfigured bot must not record voice.
DISCORD_ADMIN_USER_IDS=

# ----- Telegram (optional - upload + recap notify surface, v0.2) -----
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to forward audio (empty = nobody)
TELEGRAM_ALLOWED_CHAT_IDS=

# ----- Storage -----
# Per-session recording folders. On the VPS, use /var/lib/zaoscribe to keep
# recordings outside the app directory (systemd unit assumes this path).
RECORDINGS_DIR=/var/lib/zaoscribe/recordings
# Public base URL for download links (optional)
PUBLIC_BASE_URL=

# ----- Transcription handoff -----
# Webhook on Zaal's mac running the /meeting pipeline.
# MUST be https:// in production - the bot refuses to boot if not HTTPS and
# NODE_ENV=production. Payload includes participant userIDs (hashed) -
# treat the URL + secret as PII-bearing.
TRANSCRIBE_WEBHOOK_URL=
# Generate with: openssl rand -hex 32
# Payloads are HMAC-SHA256 signed: header x-zaoscribe-signature: sha256=<hex>
# over `${timestamp}.${rawBody}`. Receiver MUST verify timestamp <= 5min skew
# and constant-time-compare the signature.
TRANSCRIBE_WEBHOOK_SECRET=

# Hard cap on monthly transcription spend (USD); reserved for v0.2 OpenAI fallback
MAX_MONTHLY_TRANSCRIBE_USD=20

# ----- Logging -----
LOG_LEVEL=info
NODE_ENV=production
