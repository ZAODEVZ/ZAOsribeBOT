# ZAOscribe environment - copy to .env and fill values. NEVER commit .env.

# ----- Discord (required for voice recording) -----
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=
# Comma-separated user IDs allowed to run /scribe (leave empty = anyone in guild)
DISCORD_ADMIN_USER_IDS=

# ----- Telegram (optional - upload + recap notify surface) -----
TELEGRAM_BOT_TOKEN=
# Comma-separated chat IDs allowed to forward audio (leave empty = anyone)
TELEGRAM_ALLOWED_CHAT_IDS=

# ----- Storage -----
# Where per-session recording folders land
RECORDINGS_DIR=./recordings
# Public base URL (for download links posted back to Discord/Telegram); leave empty to omit
PUBLIC_BASE_URL=

# ----- Transcription handoff (one of these) -----
# Option A: webhook to Zaal's mac running /meeting pipeline
TRANSCRIBE_WEBHOOK_URL=
TRANSCRIBE_WEBHOOK_SECRET=
# Option B: OpenAI Whisper API fallback
OPENAI_API_KEY=
# Hard cap on monthly transcription spend (USD); bot refuses API calls past this
MAX_MONTHLY_TRANSCRIBE_USD=20

# ----- Logging -----
LOG_LEVEL=info
NODE_ENV=production
