{
  "name": "zaoscribe",
  "version": "0.1.0",
  "description": "ZAOscribe - Discord voice + Telegram upload meeting capture bot for The ZAO. Replaces Craig with auto-processing into the /meeting pipeline.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc --noEmit",
    "register-commands": "tsx src/scripts/register-commands.ts",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.18.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "prism-media": "^1.3.5",
    "sodium-native": "^4.3.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZAODEVZ/ZAOsribeBOT.git"
  }
}
